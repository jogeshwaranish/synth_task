# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- Strava API (https://www.strava.com/settings/api) ---
# Create a "My API Application". Set the app's Authorization Callback Domain
# to "localhost". client_id is public-ish; client_secret is a secret.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# athlete_id we tag Strava-sourced rows with ("basil" | "anish").
STRAVA_ATHLETE_ID=basil
# Localhost port the OAuth redirect is caught on. Must match nothing else local.
STRAVA_REDIRECT_PORT=8721
# Scope needed to read all activities (incl. private/trainer). Rarely changed.
STRAVA_SCOPE=activity:read_all

# --- Anthropic (synthesize/agent.py) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Google Sheets (live source; the .xlsx fixture needs none of this) ---
# Path to an OAuth client_secret.json or service-account JSON. Optional for now.
GOOGLE_CREDENTIALS_JSON=
# The founder's (AG's) sheet.
GOOGLE_SHEET_ID=

# --- Storage ---
SYNTH_DB_PATH=synth.db
# Where OAuth token caches live (gitignored). Refresh tokens rotate here.
SYNTH_TOKEN_DIR=.tokens
